{
  "_comment": "Portable mirror of the LIVE design tokens. Source of truth is tokens.css (foundational scale, light-first, Untitled-UI-derived) plus the per-surface palettes declared inline in each prototype's :root/.light. This file documents both layers; it is not consumed at runtime.",
  "_meta": {
    "palette": "multi-surface (dark-first portfolio + light architect mirror + classified + CRT + SOC severity)",
    "live_sources": ["tokens.css", "styles.css", "design-system/colors_and_type.css", "per-page inline :root/.light"],
    "updated": "2026-06-28"
  },

  "foundation": {
    "_comment": "Shared scale from tokens.css — used across case studies and the SOC dashboard (styles.css builds on it).",
    "font": {
      "display": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "body": "'DM Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', 'Roboto Mono', ui-monospace, monospace",
      "retro": "'VT323', monospace"
    },
    "type": {
      "_comment": "Untitled-UI display + text scale (tokens.css). Display sizes shrink at <=767px via media query.",
      "display": {
        "xl": {"size": "72px", "weight": 500, "lineHeight": 1.25, "tracking": "-1.44px", "mobile": "36px"},
        "lg": {"size": "60px", "weight": 500, "lineHeight": 1.2, "tracking": "-1.2px", "mobile": "32px"},
        "md": {"size": "48px", "weight": 500, "lineHeight": 1.25, "tracking": "-0.96px", "mobile": "28px"},
        "sm": {"size": "36px", "weight": 500, "lineHeight": 1.22, "tracking": "-0.72px", "mobile": "24px"},
        "xs": {"size": "30px", "weight": 500, "lineHeight": 1.27, "tracking": "0"}
      },
      "text": {
        "xl": {"size": "24px", "lineHeight": 1.33},
        "lg": {"size": "20px", "lineHeight": 1.5},
        "md": {"size": "18px", "lineHeight": 1.56},
        "sm": {"size": "16px", "lineHeight": 1.5, "_note": "body default"},
        "xs": {"size": "14px", "lineHeight": 1.43},
        "xxs": {"size": "12px", "lineHeight": 1.5}
      },
      "hero_clamp": {
        "_comment": "Prototype heroes use clamp() beyond the static scale.",
        "interactive": "clamp(40px, 7.4vw, 118px)",
        "retro_vt323": "clamp(60px, 13vw, 168px)"
      }
    },
    "space": {
      "none": "0", "xxs": "2px", "xs": "4px", "sm": "8px", "md": "12px", "lg": "16px",
      "xl": "20px", "2xl": "24px", "3xl": "32px", "4xl": "48px", "5xl": "64px",
      "6xl": "96px", "7xl": "128px", "section": "96px"
    },
    "radius": {
      "none": "0", "xxs": "2px", "xs": "4px", "sm": "6px", "md": "8px", "lg": "12px",
      "xl": "16px", "2xl": "20px", "3xl": "24px", "4xl": "28px", "pill": "9999px", "full": "50%"
    },
    "shadow": {
      "_comment": "Light-surface elevation (tokens.css). Dark surfaces use long soft shadows, see surfaces.",
      "xs": "0 1px 2px rgba(16,24,40,0.05)",
      "sm": "0 1px 3px rgba(16,24,40,0.1), 0 1px 2px rgba(16,24,40,0.06)",
      "md": "0 4px 8px -2px rgba(16,24,40,0.1), 0 2px 4px -2px rgba(16,24,40,0.06)",
      "lg": "0 12px 16px -4px rgba(16,24,40,0.08), 0 4px 6px -2px rgba(16,24,40,0.03)",
      "xl": "0 20px 24px -4px rgba(16,24,40,0.08), 0 8px 8px -4px rgba(16,24,40,0.03)",
      "2xl": "0 24px 48px -12px rgba(16,24,40,0.18)",
      "3xl": "0 32px 64px -12px rgba(16,24,40,0.14)",
      "dark_card": "0 30px 80px -40px rgba(0,0,0,0.8)"
    },
    "transition": {"fast": "150ms ease", "base": "250ms ease", "slow": "350ms ease"},
    "brand": {
      "_comment": "Color-card accents with paired on-* text (tokens.css). Used sparingly, one block per viewport.",
      "pink": {"bg": "#d63b75", "on": "#ffffff"},
      "teal": {"bg": "#0d5350", "on": "#ffffff"},
      "lavender": {"bg": "#8b6fd9", "on": "#ffffff"},
      "peach": {"bg": "#ff9d66", "on": "#0a0a0a"},
      "ochre": {"bg": "#d4a036", "on": "#0a0a0a"},
      "mint": {"bg": "#4ca88f", "on": "#ffffff"},
      "coral": {"bg": "#e64d3c", "on": "#ffffff", "_note": "strongest risk signal — never a generic stoplight red"}
    }
  },

  "surfaces": {
    "_comment": "Color palettes layered on the foundation, one per page family. Meaning never rides on hue alone.",
    "interactive": {
      "_note": "Primary homepage + About/Work/case studies. Dark default with a light 'architect' mirror.",
      "dark": {
        "bg": "#070b12", "bg2": "#0c121e", "bg3": "#121a28",
        "fg": "#e9eef7", "fg2": "#8593a8", "fg3": "#97a3b8",
        "line": "rgba(255,255,255,0.08)", "line2": "rgba(255,255,255,0.15)",
        "ac": "#4ca88f", "ac2": "#7dd3c0", "grid": "rgba(76,168,143,0.045)"
      },
      "light": {
        "bg": "#fffcf5", "bg2": "#f7f2e6", "bg3": "#ebe6d6",
        "fg": "#0a0a0a", "fg2": "#595959", "fg3": "#5e5e5e",
        "line": "rgba(0,0,0,0.09)", "line2": "rgba(0,0,0,0.16)",
        "ac": "#0d5350", "ac2": "#4ca88f", "grid": "rgba(13,83,80,0.05)"
      }
    },
    "dossier": {
      "_note": "Classified case-file homepage variant.",
      "bg": "#f4ead2", "ink": "#0a0a0a", "accent": "#b23a2e", "status": "#1c6b39"
    },
    "retro": {
      "_note": "CRT terminal homepage variant. Phosphor green on near-black.",
      "bg": "#040806", "phosphor": "#6cf0a4", "phosphor_bright": "#cdffe2",
      "phosphor_dim": "#3f9e69", "amber": "#ffb454"
    },
    "ctoc": {
      "_note": "SOC / CTOC dashboard severity scale (styles.css). Always paired with shape/label, never hue alone.",
      "critical": "#b91c1c", "high": "#e64d3c", "medium": "#d4a036",
      "low": "#1570ef", "resolved": "#15803d", "info": "#595959",
      "dark_canvas": "#0b0f14", "dark_ink": "#f3f1ea"
    }
  }
}
