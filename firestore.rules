rules_version = '2';
// Security rules for the homepage reader poll (poll.js → collection "polls", doc "homepage").
// The doc stores only three integer counts (no personal data), so open read + increment-only
// writes on that single document are safe for a public poll. Everything else stays locked.
service cloud.firestore {
  match /databases/{database}/documents {

    match /polls/homepage {
      allow read: if true;
      // only allow writes that touch the three known count fields
      allow write: if request.resource.data.keys().hasOnly(['interactive', 'dossier', 'retro']);
    }

    // deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
